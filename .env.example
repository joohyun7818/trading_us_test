# ============================================================
# AlphaFlow US — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Security ────────────────────────────────────────────────
# API key for protecting write operations (leave empty to disable authentication)
API_KEY=your_secret_api_key_here
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── PostgreSQL Database ─────────────────────────────────────
# Connection string for asyncpg driver
DATABASE_URL=postgresql://alphaflow:alphaflow123@localhost:5432/alphaflow_us

# ── Alpaca API (Paper Trading / Live) ───────────────────────
# Get your keys at https://app.alpaca.markets/signup
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Paper: https://paper-api.alpaca.markets  |  Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Finnhub News API ───────────────────────────────────────
# Get your key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Ollama (Local LLM Runtime) ──────────────────────────────
# Base URL for the Ollama server
OLLAMA_BASE_URL=http://localhost:11434
# Model names used for each task
OLLAMA_FAST_MODEL=qwen3:4b
OLLAMA_DEEP_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen3-vl:8b
OLLAMA_EMBED_MODEL=bge-m3
# Keep alive duration (0 = unload after each request, saves memory)
OLLAMA_KEEP_ALIVE=0
# Timeout in seconds for each operation
OLLAMA_TIMEOUT_GENERATE=120
OLLAMA_TIMEOUT_EMBED=60
OLLAMA_TIMEOUT_VISION=180

# ── Analysis Mode ───────────────────────────────────────────
# text_numeric: Text + Numeric only (no vision model needed)
# full: Text + Numeric + Visual (requires qwen3-vl:8b)
ANALYSIS_MODE=text_numeric

# ── Application Settings ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
